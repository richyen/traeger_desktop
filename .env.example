# Traeger Authentication
# Use your Traeger account credentials (email and password from the Traeger app)
TRAEGER_EMAIL=your.email@example.com
TRAEGER_PASSWORD=your_password_here

# Database Configuration
DB_PATH=/app/data/traeger.db

# Monitoring Settings
# How often to poll the grill for temperature updates (in seconds)
POLL_INTERVAL=30

# ===============================================================
# SETUP INSTRUCTIONS:
# ===============================================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and fill in your Traeger credentials:
#    - TRAEGER_EMAIL: The email address you use to log into the Traeger mobile app
#    - TRAEGER_PASSWORD: The password for your Traeger account
#
# 3. Run the application:
#    docker compose up
#
# That's it! The application will automatically:
#    - Authenticate with Traeger's servers using your credentials
#    - Obtain and manage authentication tokens
#    - Connect to your grill and start monitoring temperatures
#
# No need to extract tokens or configure anything else!
# ===============================================================
